{
  "name": "frontend-mandatendatabank",
  "version": "0.14.3",
  "private": true,
  "description": "Frontend of the mandatendatabank",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lblod/frontend-mandatendatabank.git"
  },
  "license": "MIT",
  "author": "info@redpencil.io",
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "build": "ember build --environment=production",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"npm:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "lint:dependencies": "ember dependency-lint",
    "lint:css": "stylelint --allow-empty-input \"**/*.css\"",
    "lint:css:fix": "concurrently \"npm:lint:css -- --fix\"",
    "lint:fix": "concurrently \"npm:lint:*:fix\" --names \"fix:\" --prefixColors auto && npm run format",
    "lint:format": "prettier . --cache --check",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "release": "release-it",
    "start": "ember serve",
    "start:prod": "ember serve --environment=production",
    "test": "concurrently \"npm:lint\" \"npm:test:*\" --names \"lint,test:\" --prefixColors auto",
    "test:ember": "ember test"
  },
  "devDependencies": {
    "@appuniversum/ember-appuniversum": "^3.18.0",
    "@babel/core": "^7.28.4",
    "@babel/eslint-parser": "^7.28.4",
    "@babel/plugin-proposal-decorators": "^7.28.0",
    "@ember/optional-features": "^2.2.0",
    "@ember/test-helpers": "^5.2.2",
    "@embroider/macros": "^1.20.2",
    "@eslint/js": "^9.35.0",
    "@glimmer/component": "^2.0.0",
    "@glimmer/tracking": "^1.1.2",
    "broccoli-asset-rev": "^3.0.0",
    "concurrently": "^9.2.1",
    "ember-auto-import": "^2.10.0",
    "ember-browser-update": "0.1.1",
    "ember-cli": "~6.7.2",
    "ember-cli-app-version": "^7.0.0",
    "ember-cli-babel": "^8.2.0",
    "ember-cli-clean-css": "^3.0.0",
    "ember-cli-dependency-checker": "^3.3.3",
    "ember-cli-dependency-lint": "^2.0.1",
    "ember-cli-deprecation-workflow": "^3.4.0",
    "ember-cli-fastboot": "^4.1.2",
    "ember-cli-htmlbars": "^6.3.0",
    "ember-cli-inject-live-reload": "^2.1.0",
    "ember-cli-sass": "^11.0.1",
    "ember-cli-sri": "^2.1.1",
    "ember-cli-terser": "^4.0.2",
    "ember-concurrency": "^3.1.1",
    "ember-data": "~5.6.0",
    "ember-load-initializers": "^3.0.1",
    "ember-modifier": "^4.2.2",
    "ember-moment": "^10.0.0",
    "ember-mu-transform-helpers": "^2.1.3",
    "ember-page-title": "^9.0.3",
    "ember-plausible": "^0.3.0",
    "ember-power-select": "^7.0.0",
    "ember-qunit": "^9.0.3",
    "ember-rdfa-helpers": "^0.6.0",
    "ember-resolver": "^13.1.1",
    "ember-source": "~6.7.0",
    "ember-template-imports": "^4.3.0",
    "ember-template-lint": "^6.1.0",
    "ember-truth-helpers": "^3.1.1",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-ember": "^12.7.3",
    "eslint-plugin-n": "^17.21.3",
    "eslint-plugin-qunit": "^8.2.5",
    "globals": "^15.15.0",
    "loader.js": "^4.7.0",
    "moment": "^2.30.1",
    "prettier": "^3.6.2",
    "prettier-plugin-ember-template-tag": "^2.1.0",
    "qunit": "^2.24.1",
    "qunit-dom": "^3.5.0",
    "release-it": "^17.3.0",
    "sass": "^1.77.5",
    "stylelint": "^16.23.1",
    "stylelint-config-standard": "^36.0.1",
    "tracked-built-ins": "^3.4.0",
    "webpack": "^5.101.3"
  },
  "fastbootDependencies": [
    "crypto"
  ],
  "engines": {
    "node": ">= 20.11"
  },
  "ember": {
    "edition": "octane"
  }
}
